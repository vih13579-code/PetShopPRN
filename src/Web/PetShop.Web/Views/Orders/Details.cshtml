@model OrderVm
@{ViewData["Title"]="Chi tiết đơn";}<h2>@Model.OrderCode</h2><p>@Model.ReceiverName - @Model.ReceiverPhone</p><p>@Model.ShippingAddress</p><p>Trạng thái: <strong>@Model.Status</strong> | Thanh toán: @Model.PaymentStatus</p><table class="table"><tbody>@foreach(var i in Model.Items){<tr><td>@i.ProductName @i.VariantName</td><td>@i.Quantity</td><td>@i.LineTotal.ToString("N0")</td></tr>}</tbody></table><h4>@Model.TotalAmount.ToString("N0") đ</h4>

@if(Model.PaymentStatus=="Pending"||Model.PaymentStatus=="CodPending"){<div class="mt-3"><form asp-controller="Payments" asp-action="Create" method="post" class="d-inline"><input type="hidden" name="orderId" value="@Model.Id"/><input type="hidden" name="method" value="COD"/><button class="btn btn-outline-secondary">Thanh toán COD</button></form><form asp-controller="Payments" asp-action="Create" method="post" class="d-inline"><input type="hidden" name="orderId" value="@Model.Id"/><input type="hidden" name="method" value="BankTransferMock"/><button class="btn btn-primary">Chuyển khoản mô phỏng</button></form></div>}
