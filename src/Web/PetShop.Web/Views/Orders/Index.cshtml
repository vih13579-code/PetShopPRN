@model IReadOnlyCollection<OrderVm>
@{ViewData["Title"]="Đơn hàng";}<h2>Đơn hàng của tôi</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<table class="table"><thead><tr><th>Mã</th><th>Shop</th><th>Tổng</th><th>Trạng thái</th><th>Thanh toán</th><th></th></tr></thead><tbody>@foreach(var o in Model){<tr><td>@o.OrderCode</td><td>@o.ShopId</td><td>@o.TotalAmount.ToString("N0")</td><td>@o.Status</td><td>@o.PaymentStatus</td><td><a asp-action="Details" asp-route-id="@o.Id">Chi tiết</a>@if(o.Status=="Pending"){<form asp-action="Cancel" method="post" class="d-inline"><input type="hidden" name="id" value="@o.Id"/><button class="btn btn-sm btn-danger">Hủy</button></form>}</td></tr>}</tbody></table>
