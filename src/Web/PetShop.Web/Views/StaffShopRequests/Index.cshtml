@model IReadOnlyCollection<ShopRequestVm>
@{ViewData["Title"]="Duyệt Shop";}<h2>Staff - Yêu cầu mở Shop</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<table class="table"><thead><tr><th>Shop</th><th>Chủ</th><th>Liên hệ</th><th>Trạng thái</th><th>Xử lý</th></tr></thead><tbody>@foreach(var x in Model){<tr><td>@x.ShopName<br/><small>@x.Address</small></td><td>@x.OwnerName</td><td>@x.Email<br/>@x.Phone</td><td>@x.Status</td><td>@if(x.Status=="Pending"){<form asp-action="Approve" method="post" class="d-inline"><input type="hidden" name="id" value="@x.Id"/><button class="btn btn-sm btn-success">Duyệt</button></form><form asp-action="Reject" method="post" class="mt-1"><input type="hidden" name="id" value="@x.Id"/><input name="reason" required placeholder="Lý do"/><button class="btn btn-sm btn-danger">Từ chối</button></form>}</td></tr>}</tbody></table>
