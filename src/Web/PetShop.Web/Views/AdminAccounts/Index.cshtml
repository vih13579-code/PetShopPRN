@model IReadOnlyCollection<UserVm>
@{ViewData["Title"]="Tài khoản";}<h2>Admin - Tài khoản</h2><a class="btn btn-success mb-3" asp-action="CreateStaff">Tạo Staff</a><form method="get" class="d-flex mb-3"><input name="keyword" value="@ViewBag.Keyword" class="form-control me-2"/><button class="btn btn-primary">Tìm</button></form>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<table class="table"><thead><tr><th>Tên</th><th>Email</th><th>Role</th><th>Trạng thái</th><th></th></tr></thead><tbody>@foreach(var u in Model){<tr><td>@u.FullName</td><td>@u.Email</td><td>@string.Join(",",u.Roles)</td><td>@(u.IsActive?"Active":"Locked")</td><td><form method="post" asp-action="@(u.IsActive?"Lock":"Unlock")"><input type="hidden" name="id" value="@u.Id"/><button class="btn btn-sm @(u.IsActive?"btn-danger":"btn-success")">@(u.IsActive?"Khóa":"Mở")</button></form></td></tr>}</tbody></table>
