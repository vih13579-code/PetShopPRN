@model IReadOnlyCollection<InventoryVm>
@{ViewData["Title"]="Tồn kho";}<h2>Tồn kho của Shop</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<form asp-action="Set" method="post" class="row g-2 mb-3"><div class="col"><input name="productId" class="form-control" required placeholder="ProductId"/></div><div class="col"><input name="quantity" type="number" min="0" class="form-control" required/></div><div class="col"><input name="reason" class="form-control" placeholder="Lý do"/></div><div class="col-auto"><button class="btn btn-primary">Cập nhật</button></div></form><table class="table"><thead><tr><th>ProductId</th><th>Tổng</th><th>Đang giữ</th><th>Có thể bán</th></tr></thead><tbody>@foreach(var i in Model){<tr><td>@i.ProductId</td><td>@i.Quantity</td><td>@i.ReservedQuantity</td><td>@i.AvailableQuantity</td></tr>}</tbody></table>
