@model CartVm
@{ViewData["Title"]="Giỏ hàng";}<h2>Giỏ hàng</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<table class="table"><thead><tr><th>Sản phẩm</th><th>Giá</th><th>SL</th><th>Thành tiền</th><th></th></tr></thead><tbody>@foreach(var i in Model.Items){<tr><td>@i.ProductName @i.VariantName</td><td>@i.UnitPrice.ToString("N0")</td><td>@i.Quantity</td><td>@i.LineTotal.ToString("N0")</td><td><form asp-action="Remove" method="post"><input type="hidden" name="itemId" value="@i.Id"/><button class="btn btn-sm btn-danger">Xóa</button></form></td></tr>}</tbody></table><h4>Tổng: @Model.Total.ToString("N0") đ</h4><a class="btn btn-primary" asp-action="Checkout">Thanh toán</a>
