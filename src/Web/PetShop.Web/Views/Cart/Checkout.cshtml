@model CheckoutVm
@{ViewData["Title"]="Đặt hàng";}<h2>Thông tin nhận hàng</h2><form method="post" class="col-md-6"><div asp-validation-summary="All" class="text-danger"></div><label asp-for="ReceiverName"></label><input asp-for="ReceiverName" class="form-control mb-2"/><label asp-for="ReceiverPhone"></label><input asp-for="ReceiverPhone" class="form-control mb-2"/><label asp-for="ShippingAddress"></label><textarea asp-for="ShippingAddress" class="form-control mb-2"></textarea><label asp-for="Note"></label><textarea asp-for="Note" class="form-control mb-2"></textarea><label>Phí giao hàng mỗi Shop</label><input asp-for="ShippingFeePerShop" class="form-control mb-2"/><label>Thanh toán</label><select asp-for="PaymentMethod" class="form-select mb-3"><option value="COD">COD</option><option value="BankTransferMock">Chuyển khoản mô phỏng</option></select><button class="btn btn-success">Đặt hàng</button></form>
