@model PagedVm<ProductVm>
@{ViewData["Title"]="Sản phẩm";}<h2>Sản phẩm</h2><form method="get" class="d-flex mb-3"><input name="keyword" value="@ViewBag.Keyword" class="form-control me-2" placeholder="Tìm kiếm..."/><button class="btn btn-outline-primary">Tìm</button></form>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<div class="row g-3">@foreach(var p in Model.Items){<div class="col-md-4"><div class="card h-100">@if(!string.IsNullOrWhiteSpace(p.ImageUrl)){<img src="@p.ImageUrl" class="card-img-top" style="height:200px;object-fit:cover"/>}<div class="card-body"><h5>@p.Name</h5><p>@p.Price.ToString("N0") đ</p><a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@p.Id">Chi tiết</a></div></div></div>}</div>
