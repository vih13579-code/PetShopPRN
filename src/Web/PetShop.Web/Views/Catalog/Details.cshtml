@model ProductVm
@{ViewData["Title"]=Model.Name;}<h2>@Model.Name</h2><p>Danh mục: @Model.CategoryName</p><p>@Model.Description</p><h4>@Model.Price.ToString("N0") đ</h4><form asp-controller="Cart" asp-action="Add" method="post"><input type="hidden" name="productId" value="@Model.Id"/><select name="variantId" class="form-select mb-2"><option value="">Mặc định</option>@foreach(var v in Model.Variants.Where(x=>x.IsActive)){<option value="@v.Id">@v.Name (+@v.AdditionalPrice.ToString("N0") đ)</option>}</select><input type="number" name="quantity" min="1" value="1" class="form-control mb-2"/><button class="btn btn-success">Thêm vào giỏ</button></form>
