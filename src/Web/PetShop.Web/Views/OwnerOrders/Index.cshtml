@model IReadOnlyCollection<OrderVm>
@{ViewData["Title"]="Đơn hàng Shop";}
<h2>Đơn hàng của Shop</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}
<table class="table"><thead><tr><th>Mã</th><th>Tổng</th><th>Trạng thái</th><th>Thao tác</th></tr></thead><tbody>@foreach(var o in Model){<tr><td>@o.OrderCode</td><td>@o.TotalAmount.ToString("N0")</td><td>@o.Status</td><td>@if(o.Status=="Pending"){<form asp-action="Confirm" method="post" class="d-inline"><input type="hidden" name="id" value="@o.Id"/><button class="btn btn-sm btn-success">Xác nhận</button></form>}@if(o.Status=="Confirmed"){<form asp-action="Preparing" method="post" class="d-inline"><input type="hidden" name="id" value="@o.Id"/><button class="btn btn-sm btn-primary">Chuẩn bị</button></form>}@if(o.Status=="Preparing"){<form asp-action="Shipping" method="post" class="d-inline"><input type="hidden" name="id" value="@o.Id"/><button class="btn btn-sm btn-primary">Giao hàng</button></form>}@if(o.Status=="Shipping"){<form asp-action="Complete" method="post" class="d-inline"><input type="hidden" name="id" value="@o.Id"/><button class="btn btn-sm btn-success">Hoàn thành</button></form>}@if(o.Status=="Pending"||o.Status=="Confirmed"||o.Status=="Preparing"){<form asp-action="Cancel" method="post" class="d-inline"><input type="hidden" name="id" value="@o.Id"/><button class="btn btn-sm btn-danger">Hủy</button></form>}</td></tr>}</tbody></table>
