@model ShopEditVm
@{ViewData["Title"]="Shop của tôi";}<h2>Shop của tôi</h2>@if(Model==null){<div class="alert alert-warning">@ViewBag.Error</div>}else{<form method="post" class="col-md-7"><input type="hidden" asp-for="Id"/><input type="hidden" asp-for="OwnerUserId"/><label>Tên</label><input asp-for="Name" class="form-control mb-2"/><label>Mô tả</label><textarea asp-for="Description" class="form-control mb-2"></textarea><label>Điện thoại</label><input asp-for="Phone" class="form-control mb-2"/><label>Email</label><input asp-for="Email" class="form-control mb-2"/><label>Địa chỉ</label><textarea asp-for="Address" class="form-control mb-2"></textarea><label>Mã số thuế</label><input asp-for="TaxCode" class="form-control mb-2"/><button class="btn btn-success">Lưu</button></form>}