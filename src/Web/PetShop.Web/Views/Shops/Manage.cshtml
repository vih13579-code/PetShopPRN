@model IReadOnlyCollection<ShopVm>
@{ViewData["Title"]="Quản lý Shop";}<h2>Danh sách Shop</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<table class="table"><thead><tr><th>Tên</th><th>Chủ</th><th>Trạng thái</th><th></th></tr></thead><tbody>@foreach(var s in Model){<tr><td>@s.Name</td><td>@s.OwnerUserId</td><td>@s.Status</td><td><form method="post" asp-action="@(s.Status=="Active"?"Lock":"Unlock")"><input type="hidden" name="id" value="@s.Id"/><button class="btn btn-sm">@(s.Status=="Active"?"Khóa":"Mở")</button></form></td></tr>}</tbody></table>