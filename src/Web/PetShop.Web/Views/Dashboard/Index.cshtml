@model UserVm
@{ViewData["Title"]="Dashboard";}<h2>Dashboard</h2>@if(Model==null){<div class="alert alert-warning">Không đọc được phiên đăng nhập.<a class="list-group-item" asp-controller="OwnerOrders" asp-action="Index">Chủ Shop xử lý đơn hàng</a><a class="list-group-item" asp-controller="Shops" asp-action="Mine">Thông tin Shop của tôi</a><a class="list-group-item" asp-controller="Shops" asp-action="Manage">Admin/Staff quản lý Shop</a></div>}else{<p>Xin chào <strong>@Model.FullName</strong> (@string.Join(", ",Model.Roles))</p><div class="list-group"><a class="list-group-item" asp-controller="ShopRegistration" asp-action="Index">Yêu cầu mở Shop</a><a class="list-group-item" asp-controller="AdminAccounts" asp-action="Index">Admin quản lý tài khoản</a><a class="list-group-item" asp-controller="StaffShopRequests" asp-action="Index">Staff duyệt Shop</a><a class="list-group-item" asp-controller="OwnerCatalog" asp-action="Categories">Chủ Shop quản lý danh mục</a><a class="list-group-item" asp-controller="OwnerCatalog" asp-action="Products">Chủ Shop quản lý sản phẩm</a><a class="list-group-item" asp-controller="Inventory" asp-action="Index">Chủ Shop quản lý tồn kho</a><a class="list-group-item" asp-controller="OwnerOrders" asp-action="Index">Chủ Shop xử lý đơn hàng</a><a class="list-group-item" asp-controller="Shops" asp-action="Mine">Thông tin Shop của tôi</a><a class="list-group-item" asp-controller="Shops" asp-action="Manage">Admin/Staff quản lý Shop</a></div>}
