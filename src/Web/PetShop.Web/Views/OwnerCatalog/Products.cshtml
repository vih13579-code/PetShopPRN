@model IReadOnlyCollection<ProductVm>
@{ViewData["Title"]="Sản phẩm Shop";}<h2>Sản phẩm của Shop</h2><a class="btn btn-primary mb-3" asp-action="CreateProduct">Tạo sản phẩm</a>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<table class="table"><thead><tr><th>Tên</th><th>Danh mục</th><th>Giá</th><th>Trạng thái</th><th></th></tr></thead><tbody>@foreach(var p in Model){<tr><td>@p.Name</td><td>@p.CategoryName</td><td>@p.Price.ToString("N0")</td><td>@p.IsActive</td><td><form asp-action="DeleteProduct" method="post"><input type="hidden" name="id" value="@p.Id"/><button class="btn btn-sm btn-danger">Ngừng bán</button></form></td></tr>}</tbody></table>
