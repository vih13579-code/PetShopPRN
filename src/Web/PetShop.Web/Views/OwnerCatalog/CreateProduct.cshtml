@model ProductFormVm
@{ViewData["Title"]="Tạo sản phẩm";var categories=(IReadOnlyCollection<CategoryVm>)(ViewBag.Categories??Array.Empty<CategoryVm>());}<h2>Tạo sản phẩm</h2><form method="post" class="col-md-7"><div asp-validation-summary="All" class="text-danger"></div><label>Danh mục</label><select asp-for="CategoryId" class="form-select mb-2">@foreach(var c in categories){<option value="@c.Id">@c.Name</option>}</select><label asp-for="Name"></label><input asp-for="Name" class="form-control mb-2"/><label asp-for="Description"></label><textarea asp-for="Description" class="form-control mb-2"></textarea><label asp-for="Price"></label><input asp-for="Price" class="form-control mb-2"/><label asp-for="ImageUrl"></label><input asp-for="ImageUrl" class="form-control mb-2"/><label><input asp-for="IsActive"/> Đang bán</label><br/><button class="btn btn-success mt-2">Lưu</button></form>
