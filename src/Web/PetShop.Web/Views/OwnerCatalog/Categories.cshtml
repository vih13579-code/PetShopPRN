@model IReadOnlyCollection<CategoryVm>
@{ViewData["Title"]="Danh mục Shop";}<h2>Danh mục của Shop</h2>@if(ViewBag.Error!=null){<div class="alert alert-danger">@ViewBag.Error</div>}<form asp-action="CreateCategory" method="post" class="row g-2 mb-3"><div class="col"><input name="Name" class="form-control" required placeholder="Tên danh mục"/></div><div class="col"><input name="Description" class="form-control" placeholder="Mô tả"/></div><div class="col-auto"><button class="btn btn-success">Thêm</button></div></form><table class="table"><tbody>@foreach(var c in Model){<tr><td>@c.Name</td><td>@c.Description</td><td><form asp-action="DeleteCategory" method="post"><input type="hidden" name="id" value="@c.Id"/><button class="btn btn-sm btn-danger">Xóa</button></form></td></tr>}</tbody></table>
