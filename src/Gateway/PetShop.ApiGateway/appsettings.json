{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-profile": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        }
      },
      "identity-admin": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/admin/accounts/{**catch-all}"
        }
      },
      "shop-requests": {
        "ClusterId": "shops",
        "Match": {
          "Path": "/api/shop-requests/{**catch-all}"
        }
      },
      "shops": {
        "ClusterId": "shops",
        "Match": {
          "Path": "/api/shops/{**catch-all}"
        }
      },
      "catalog-public": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/catalog/{**catch-all}"
        }
      },
      "catalog-owner": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/owner/catalog/{**catch-all}"
        }
      },
      "inventory": {
        "ClusterId": "inventory",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },
      "cart": {
        "ClusterId": "orders",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        }
      },
      "orders": {
        "ClusterId": "orders",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "payments": {
        "ClusterId": "payments",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },
      "notifications": {
        "ClusterId": "notifications",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7001/"
          }
        }
      },
      "shops": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7002/"
          }
        }
      },
      "catalog": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7003/"
          }
        }
      },
      "inventory": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7004/"
          }
        }
      },
      "orders": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7005/"
          }
        }
      },
      "payments": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7006/"
          }
        }
      },
      "notifications": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:7007/"
          }
        }
      }
    }
  }
}